{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CareerOS Local",
  "version": "1.1.0",
  "identifier": "local.careeros.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "CareerOS Local",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "capabilities": ["main"],
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost http://127.0.0.1:*",
        "font-src": "'self' data:",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'"
      },
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "resources": {
      "binaries/careeros-backend-runtime/": "careeros-backend-runtime/"
    },
    "targets": "all",
    "createUpdaterArtifacts": false,
    "category": "Productivity",
    "shortDescription": "Private, local-first career workspace",
    "longDescription": "CareerOS Local turns verified career history into resumes, opportunities and applications while keeping private data and optional AI inference on your computer.",
    "copyright": "Copyright © 2026 CareerOS Local contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
