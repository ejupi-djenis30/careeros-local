{
  "name": "careeros-local-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "CareerOS Local desktop application",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "desktop:prepare": "python ../scripts/build_backend_sidecar.py",
