# CareerOS Local — optional overrides for manual development.
# Docker Compose works without this file and generates its installation secret locally.

# Application
ENVIRONMENT=development
OFFLINE_MODE=false
PROJECT_NAME=CareerOS Local
API_V1_STR=/api/v1
LOG_LEVEL=INFO

# Loopback-only browser access
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
ALLOWED_HOSTS=["localhost","127.0.0.1","testserver"]

# Local vault. Keep SQLite and DATA_DIR on the same durable local disk.
DATABASE_URL=sqlite:///./data/careeros.db
DATA_DIR=./data
SQLITE_BUSY_TIMEOUT_MS=5000

# Authentication. Development has a safe local default. For a manual production run,
# uncomment and generate a private value with:
# python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Local inference only. Remote hosts are rejected by configuration validation.
LOCAL_INFERENCE_URL=http://127.0.0.1:11434
LOCAL_INFERENCE_ALLOWED_HOSTS=localhost,127.0.0.1,::1,ollama,host.docker.internal
LOCAL_MODEL=qwen3:1.7b
LOCAL_INFERENCE_CONNECT_TIMEOUT_SECONDS=2
LOCAL_INFERENCE_REQUEST_TIMEOUT_SECONDS=180
LLM_CONTEXT_WINDOW=8192
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9

# Local pipeline limits
SEARCH_EXECUTION_MODE=sequential
SEARCH_CONCURRENCY=3
ANALYSIS_CONCURRENCY=2
ANALYSIS_BATCH_SIZE=3
NORMALIZE_BATCH_SIZE=5
MAX_CONCURRENT_SEARCHES_PER_USER=1
SEARCH_PIPELINE_TIMEOUT_SECONDS=1800

# Upload, resume and portable-archive limits
MAX_UPLOAD_FILE_SIZE=10485760
RESUME_MAX_PAGES=3
RESUME_PHOTO_MAX_PIXELS=25000000
PORTABLE_ARCHIVE_MAX_BYTES=536870912
PORTABLE_ARCHIVE_MAX_UNCOMPRESSED_BYTES=1073741824
PORTABLE_ARCHIVE_MAX_MEMBERS=20000
PORTABLE_ARCHIVE_MAX_RECORDS=250000

# Optional deterministic local matching. A registry name is never downloaded implicitly.
SKILL_EMBEDDING_ENABLED=false
SKILL_EMBEDDING_MODEL=
