# ═══════════════════════════════════════════════════════════════════════════════
# Job Hunter AI — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:  cp .env.example .env
# Every variable listed here maps 1-to-1 to a setting in backend/core/config.py.

# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
PROJECT_NAME=Job Hunter AI
API_V1_STR=/api/v1
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ─── Network / CORS ───────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins.
# If running behind a reverse proxy or custom domain, add your domain here.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
# Optional regex for dynamic origin matching (useful for staging environments).
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
# Trusted hostnames for HTTP Host-header validation.
ALLOWED_HOSTS=["localhost","127.0.0.1","testserver"]

# ─── Security ─────────────────────────────────────────────────────────────────
# CRITICAL: Change this to a random 32+ character string in production.
#   Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECURE_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=11520   # 8 days (short-lived JWT)
REFRESH_TOKEN_EXPIRE_DAYS=30        # Long-lived refresh token

# ─── Database ─────────────────────────────────────────────────────────────────
# Docker / production (PostgreSQL — recommended):
DATABASE_URL=postgresql://postgres:password@db:5432/jobhunter
# Local development (SQLite — no extra service required):
# DATABASE_URL=sqlite:///./job_hunter.db

DB_POOL_SIZE=8      # SQLAlchemy connection pool size
DB_MAX_OVERFLOW=16  # Extra connections allowed above pool size

# ─── Postgres credentials (Docker only) ──────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password       # Change this in production!
POSTGRES_DB=jobhunter

# ═══════════════════════════════════════════════════════════════════════════════
# LLM CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
#
# The LLM layer operates in two tiers:
#   1. GLOBAL settings  — used as the fallback for every pipeline step.
#   2. PER-STEP overrides — optionally override any global setting for a
#      specific step. Leave the override empty (or use -1 for numerics) to
#      fall back to the global value.
#
# Active pipeline steps (in execution order):
#   PLAN             → generate multi-language search queries from your profile
#   NORMALIZE_PROFILE → extract structured candidate data from CV + role intent
#   NORMALIZE        → normalize raw scraped job fields into structured schema
#   MATCH            → deep profile-vs-job scoring + narrative + recommendation
#
# Supported providers:  groq | deepseek | openai | gemini | ollama
# Any OpenAI-compatible endpoint also works via LLM_BASE_URL override.
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Global LLM (fallback for all steps) ──────────────────────────────────────
LLM_PROVIDER=deepseek                          # groq | deepseek | openai | gemini | ollama
LLM_API_KEY=your_deepseek_api_key_here         # REQUIRED
LLM_BASE_URL=https://api.deepseek.com          # Provider API endpoint
LLM_MODEL=deepseek-reasoner                    # DeepSeek R1 — strong reasoning model
LLM_TEMPERATURE=0.15                           # 0.0 = deterministic, 1.0 = creative
LLM_TOP_P=0.90                                 # Nucleus sampling (0.0–1.0)
LLM_MAX_TOKENS=62000                           # Max output tokens
LLM_THINKING=true                              # Enable DeepSeek extended reasoning mode
LLM_THINKING_LEVEL=OFF                         # Gemini thinking budget: OFF | LOW | MEDIUM | HIGH

# ─── Ollama (used when LLM_PROVIDER=ollama) ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# ═══════════════════════════════════════════════════════════════════════════════
# PER-STEP OVERRIDES  (all optional — leave empty/unset to inherit global)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Step: PLAN (search query generation) ────────────────────────────────────
# Uses a fast Groq model for single-shot query generation (no batching).
# LLM_PLAN_PROVIDER=groq
# LLM_PLAN_MODEL=openai/gpt-oss-120b
# LLM_PLAN_API_KEY=your_groq_api_key_here
# LLM_PLAN_BASE_URL=https://api.groq.com/openai/v1
# LLM_PLAN_TEMPERATURE=0.60
# LLM_PLAN_TOP_P=0.90
# LLM_PLAN_MAX_TOKENS=16384
# LLM_PLAN_THINKING=false
# LLM_PLAN_THINKING_LEVEL=OFF

# ─── Step: NORMALIZE_PROFILE (CV + role intent normalization) ─────────────────
# Tip: use a deterministic (temperature=0.0) capable model for reliable extraction.
# LLM_NORMALIZE_PROFILE_PROVIDER=
# LLM_NORMALIZE_PROFILE_MODEL=
# LLM_NORMALIZE_PROFILE_API_KEY=
# LLM_NORMALIZE_PROFILE_BASE_URL=
# LLM_NORMALIZE_PROFILE_TEMPERATURE=
# LLM_NORMALIZE_PROFILE_TOP_P=
# LLM_NORMALIZE_PROFILE_MAX_TOKENS=
# LLM_NORMALIZE_PROFILE_THINKING=
# LLM_NORMALIZE_PROFILE_THINKING_LEVEL=

# ─── Step: NORMALIZE (shared job normalization) ───────────────────────────────
# Tip: same as NORMALIZE_PROFILE — deterministic extraction of structured fields.
# LLM_NORMALIZE_PROVIDER=
# LLM_NORMALIZE_MODEL=
# LLM_NORMALIZE_API_KEY=
# LLM_NORMALIZE_BASE_URL=
# LLM_NORMALIZE_TEMPERATURE=
# LLM_NORMALIZE_TOP_P=
# LLM_NORMALIZE_MAX_TOKENS=
# LLM_NORMALIZE_THINKING=
# LLM_NORMALIZE_THINKING_LEVEL=


# ─── Step: MATCH (deep job match analysis + scoring) ─────────────────────────
# Uses DeepSeek-Reasoner for deep profile-vs-job analysis (inherited from global).
# LLM_MATCH_PROVIDER=deepseek
# LLM_MATCH_MODEL=deepseek-reasoner
# LLM_MATCH_API_KEY=your_deepseek_api_key_here
# LLM_MATCH_BASE_URL=https://api.deepseek.com
# LLM_MATCH_TEMPERATURE=0.15
# LLM_MATCH_TOP_P=0.90
# LLM_MATCH_MAX_TOKENS=62000
# LLM_MATCH_THINKING=true
# LLM_MATCH_THINKING_LEVEL=OFF

# ─── Step: SUMMARY [DEPRECATED — no longer used in pipeline] ─────────────────
# NOTE: The SUMMARY step has been removed from the backend pipeline and
#       LLM_SUMMARY_* settings are no longer read by backend/core/config.py.
#       This block is kept only for historical reference and will have no effect.
# LLM_SUMMARY_PROVIDER=
# LLM_SUMMARY_MODEL=
# LLM_SUMMARY_API_KEY=
# LLM_SUMMARY_BASE_URL=
# LLM_SUMMARY_TEMPERATURE=
# LLM_SUMMARY_TOP_P=
# LLM_SUMMARY_MAX_TOKENS=
# LLM_SUMMARY_THINKING=
# LLM_SUMMARY_THINKING_LEVEL=

# ═══════════════════════════════════════════════════════════════════════════════
# SCRAPING & PIPELINE TUNING
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Scraping ─────────────────────────────────────────────────────────────────
# JOB_ROOM_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 ...
MAX_DESCRIPTION_CHARS=64000    # Characters to retain from raw job descriptions (higher = richer context)

# ─── File uploads ─────────────────────────────────────────────────────────────
MAX_UPLOAD_FILE_SIZE=10485760  # Max CV upload size in bytes (default: 10 MB)

# ─── Search execution ────────────────────────────────────────────────────────
SEARCH_EXECUTION_MODE=immediate        # immediate | scheduled
SEARCH_CONCURRENCY=3                   # Parallel scraper requests per search run
SEARCH_PLAN_ENABLE_LOOSE_DEDUP=true    # Deduplicate similar queries within single-shot generation
SEARCH_ENABLE_DEGRADED_PLAN_FALLBACK=true   # Fall back to simplified plan on LLM failure
SEARCH_DEGRADED_PLAN_MAX_QUERIES=4          # Max queries in degraded fallback plan
SEARCH_DEGRADED_PLAN_MAX_KEYWORDS=2         # Max keywords per degraded-plan query

ANALYSIS_CONCURRENCY=12    # Parallel LLM analysis calls for MATCH step
ANALYSIS_BATCH_SIZE=4      # Jobs per MATCH prompt batch (lower = more detail per job)

# ─── Normalization-based deterministic pre-screening ─────────────────────────
# When enabled, structured candidate vs. job field comparisons filter out clear
# mismatches before the expensive MATCH step runs.
SEARCH_ENABLE_NORMALIZATION_MATCHING=true
# Tolerance added to user experience years for min-experience comparisons.
# E.g. user has 3 yrs → jobs requiring up to 3+N yrs still pass the filter.
SEARCH_NORMALIZATION_EXPERIENCE_TOLERANCE=3
